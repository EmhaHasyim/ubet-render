{
  "languages": {
    "JavaScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "bun",
          "arguments": ["run", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TypeScript": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "bun",
          "arguments": ["run", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TSX": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "bun",
          "arguments": ["run", "oxfmt", "--stdin-filepath", "{buffer_path}"]
        }
      }
    }
  },
  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onType",
          "fixKind": "safe_fix"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "configPath": ".oxfmtrc.json",
          "run": "onSave"
        }
      }
    }
  }
}
